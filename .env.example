# Copia este archivo como .env y rellena tu token real.
# Nunca subas .env a git — está en .gitignore.

# ── Requerido ────────────────────────────────────────────────────────────────
BOT_TOKEN=pon_tu_token_aqui

# ── Historial persistente (opcional) ─────────────────────────────────────────
# Ruta del archivo JSON donde se guarda el historial de tiradas entre reinicios.
# Si no se define, se usa "roll_history.json" en el directorio de trabajo.
# HISTORY_FILE=roll_history.json

# ── Administración (opcional) ─────────────────────────────────────────────────
# IDs de Telegram de los admins (separados por coma). Sin esto, /admin informa
# que no hay admins configurados pero no lanza ningún error.
# ADMIN_USER_IDS=123456789,987654321

# ── Historial en memoria (opcional) ──────────────────────────────────────────
# Máximo de usuarios distintos guardados en memoria. El más antiguo se elimina
# automáticamente cuando se supera el límite (LRU). Defecto: 1000.
# MAX_HISTORY_USERS=1000

# ── Logging a archivo con rotación (opcional) ─────────────────────────────────
# Si LOG_FILE está vacío o ausente, solo se escribe en consola (comportamiento
# por defecto). Si se especifica una ruta, se crea un RotatingFileHandler.
# LOG_FILE=bot.log
# LOG_MAX_BYTES=5242880   # 5 MB por archivo
# LOG_BACKUP_COUNT=3      # número de archivos de respaldo
